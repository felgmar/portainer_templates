{
    "version": "2",
    "templates": [
        {
            "maintainer": "https://github.com/felgmar",
            "type": 1,
            "title": "AdGuard Home",
            "description": "AdGuard Home is a network-wide software for blocking ads and tracking. After you set it up, it'll cover all your home devices, and you won't need any client-side software for that.",
            "categories": [ "dns" ],
            "platform": "linux",
            "logo": "https://developer.asustor.com/uploadIcons/0020_999_1595573028_AdGuardhome_256.png",
            "image": "adguard/adguardhome:latest",
            "restart-policy": "unless-stopped",
            "container_name": "adguard-home",
            "ports": [
                "53/tcp",
                "53/udp",
                "67/udp",
                "68/tcp",
                "68/udp",
                "80/tcp",
                "853/tcp",
                "853/udp",
                "3000/tcp",
                "5443/tcp",
                "5443/udp"
            ],
            "volumes": [
                {
                    "container": "/mnt/adguardhome/config"
                },
                {
                    "container": "/mnt/adguardhome/work"
                }
            ]
        },
        {
            "maintainer": "https://github.com/felgmar",
            "type": 1,
            "title": "Nextcloud AIO",
            "description": "A safe home for all your data",
            "categories": [ "storage" ],
            "platform": "linux",
            "logo": "https://raw.githubusercontent.com/thesugarat/portainer_templates-1/master/Images/nextcloud-icon.png",
            "image": "nextcloud/all-in-one:latest",
            "init": "true",
            "restart-policy": "always",
            "container_name": "nextcloud-aio-mastercontainer",
            "network_mode": "host",
            "ports": [
                "8082:8080"
            ],
            "env": [
                {
                    "default": "11000",
                    "label": "APACHE_PORT",
                    "name": "APACHE_PORT"
                },
                {
                    "default": "0.0.0.0",
                    "label": "APACHE_IP_BINDING",
                    "name": "APACHE_IP_BINDING"
                },
                {
                    "default": "nextcloud_aio_nextcloud_datadir",
                    "label": "NEXTCLOUD_DATADIR",
                    "name": "NEXTCLOUD_DATADIR"
                },
                {
                    "default": "3478",
                    "label": "TALK_PORT",
                    "name": "TALK_PORT"
                },
                {
                    "default": "false",
                    "label": "SKIP_DOMAIN_VERIFICATION",
                    "name": "SKIP_DOMAIN_VERIFICATION"
                }
            ],
            "security_opt": [
                "label:disable"
            ],
            "volumes": [
                {
                    "bind": "nextcloud_aio_mastercontainer",
                    "container": "/mnt/docker-aio-config"
                },
                {
                    "bind": "/var/run/docker.sock",
                    "container": "/var/run/docker.sock:ro"
                }
            ]
        }
    ]
}
